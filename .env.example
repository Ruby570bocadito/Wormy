# Wormy v4.0 — Environment Configuration
# Copy this file to .env and fill in your values

# Kill switch code (overrides hardcoded default)
WORMY_KILL_SWITCH=your_secret_code_here

# JWT secret for API authentication
WORMY_JWT_SECRET=change_this_jwt_secret

# SSL verification (set to "1" to enable)
WORMY_SSL_VERIFY=0

# C2 Server
C2_SERVER=0.0.0.0
C2_PORT=8443
C2_PASSPHRASE=change_this_passphrase

# Telegram C2 (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack C2 (optional)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Google Sheets C2 (optional)
GOOGLE_SHEETS_ID=
GOOGLE_API_KEY=

# Metasploit RPC (optional)
MSF_PASSWORD=change_this_password
